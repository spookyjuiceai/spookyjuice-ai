# SpookyJuice AI Environment Configuration
# Copy this to .env and fill in your actual values

# ElevenLabs (Professional Account Required)
ELEVENLABS_API_KEY=your_elevenlabs_professional_api_key
ELEVENLABS_VOICE_ID=O91ChHz6qxVDOmtvlMKZ

# OpenAI (GPT-4 Access Required)  
OPENAI_API_KEY=sk-your-openai-api-key

# Twilio (Voice Calls)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=spookyjuice@yourdomain.com

# Webhook Configuration
VOICE_WEBHOOK_BASE=https://yourdomain.com

# Database
DATABASE_URL=sqlite:///var/lib/spookyjuice-ai/conversations.db

# Security
JWT_SECRET=your-jwt-secret-key
ENCRYPTION_KEY=your-encryption-key

# Google Services (Optional - for calendar integration)
GOOGLE_CREDENTIALS_PATH=/path/to/google-credentials.json

# CRM Integration (Optional)
HUBSPOT_API_KEY=your_hubspot_api_key
SALESFORCE_API_KEY=your_salesforce_api_key

# WhatsApp Business (Optional)
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token